      "item": [
        {
          "id": "2bbb7259-8523-457a-9612-479d946d466d",
          "name": "Send Transaction Through Block Engine",
          "request": {
            "name": "Send Transaction Through Block Engine",
            "description": {
              "content": "JSON-RPC 2.0 endpoint exposing the `sendTransaction` method. Acts as a direct proxy to Solana's `sendTransaction`, but routes the transaction through the Block Engine to the next leader for inclusion. Optional `bundleOnly=true` query parameter forces the transaction to be wrapped in a single-tx bundle so it is processed under bundle semantics.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "v1",
                "transactions"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "bundleOnly",
                  "value": "<boolean>",
                  "description": "When true, the transaction is treated as a single-transaction bundle."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
